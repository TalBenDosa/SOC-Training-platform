# HACK THE SOC — environment configuration
# Copy to .env.local and fill in. The app RUNS WITHOUT the optional keys
# (content routes fall back to stub output when a provider key is absent).
# Validated at startup by src/lib/config/env.ts. NEVER commit .env.local.

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database — Supabase / Postgres (Phase 1: accounts & persistence) ─────────
# NEXT_PUBLIC_* are exposed to the browser (safe: anon key is public by design).
# SUPABASE_SERVICE_ROLE_KEY and DATABASE_URL are SERVER-ONLY — never expose them.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgres://user:pass@host:5432/db

# ── Auth — Auth.js / NextAuth (Phase 1) ──────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── LLM providers (content generation & AI grading) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Optional OpenAI fallback / lesson tooling
OPENAI_API_KEY=

# ── Durable rate-limit store (Phase 0.7 — replaces in-memory middleware limiter)
# When set, the API rate limiter should use Upstash Redis instead of per-instance memory.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Observability (Phase 4) ──────────────────────────────────────────────────
SENTRY_DSN=
